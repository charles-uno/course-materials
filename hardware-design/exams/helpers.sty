\newcommand{\testrules}{
\begin{itemize}
  \item This is a closed-book exam. Please do not use outside resources such as notes, past work, calculators, AI, or other people. 
  \item You have one hour for this test.
  \item You may turn in your test in person or email it to me. If you email it, be sure to send a \textbf{scan} (not a photo).
  \item If your answer does not fit in the space provided, use more paper. Put your name on each page. Label your work clearly so I can tell which answer is for which question. 
  \item I have confidence in you!
\end{itemize}
}


\newcommand{\testrulesFinalExam}{
\begin{itemize}
  \item This is a closed-book exam. Please do not use outside resources such as notes, past work, or other people. 
  \item You have two hours for this exam.
  \item If your answer does not fit in the space provided, you may use a separate piece of paper. Put your name on each separate page, and label your work clearly so I can tell which answer is for which question. 
  \item I have confidence in you!
\end{itemize}
}

